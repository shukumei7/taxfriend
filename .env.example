# taxfriend — environment variables
# Copy this file to .env and fill in your keys
# All vars are prefixed TF_ to avoid conflicts with the research-server

# Server port (default: 9001)
TF_PORT=9001

# --- LLM Provider API Keys ---
# Only required if the corresponding provider is used in llm-config.json

# Anthropic SDK (type: "anthropic") — supports vision, required for PDF-as-image analysis
TF_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI SDK (type: "openai") — supports vision (GPT-4o / GPT-4o-mini)
TF_OPENAI_API_KEY=sk-...

# Ollama runs locally — no API key needed
# Configure baseUrl directly in llm-config.json providers

# --- Per-stage LLM overrides ---
# Override any stage from llm-config.json without editing the file.
# Value must match a provider name defined in llm-config.json providers.
# TF_LLM_STRUCTURE=claude-cli
# TF_LLM_PARTITION=gpt4o-mini
# TF_LLM_SYNTHESIS=claude-api
# TF_LLM_ADVISORY=claude-api
# TF_LLM_CHECKLIST=gpt4o-mini
# TF_LLM_CHAT=claude-cli
